---
import type { MarkdownHeading } from "astro";

const { headings } = Astro.props as { headings: MarkdownHeading[] };
const items = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
---
{items.length > 0 && (
  <aside class="rounded-2xl border border-black/5 bg-white/80 p-5 text-sm shadow-sm dark:border-white/10 dark:bg-white/5">
    <h2 class="mb-3 text-xs font-sans uppercase tracking-[0.2em] text-black/50 dark:text-white/50">
      On This Page
    </h2>
    <nav class="flex flex-col gap-2">
      {items.map((heading) => (
        <a
          class={`transition hover:text-[rgb(var(--accent))] ${heading.depth === 3 ? "pl-4 text-black/60 dark:text-white/60" : "font-medium"}`}
          href={`#${heading.slug}`}
        >
          {heading.text}
        </a>
      ))}
    </nav>
  </aside>
)}
