---
import ThemeToggle from "./ThemeToggle.astro";
const { title, description } = Astro.props;
---
<header class="relative">
  <div class="flex flex-col gap-6 rounded-3xl border border-black/5 bg-white/70 p-6 shadow-sm backdrop-blur dark:border-white/10 dark:bg-white/5">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div>
        <a class="text-3xl font-semibold tracking-tight" href="/">{title}</a>
        <p class="mt-2 max-w-2xl text-sm text-black/70 dark:text-white/70">
          {description}
        </p>
      </div>
      <ThemeToggle />
    </div>
    <nav class="flex flex-wrap gap-4 text-sm font-sans text-black/70 dark:text-white/70">
      <a class="transition hover:text-black dark:hover:text-white" href="/">Home</a>
      <a class="transition hover:text-black dark:hover:text-white" href="/posts">Posts</a>
      <a class="transition hover:text-black dark:hover:text-white" href="/about">About</a>
    </nav>
  </div>
</header>
