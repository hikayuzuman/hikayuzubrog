---
import type { CollectionEntry } from "astro:content";

const { entry } = Astro.props as { entry: CollectionEntry<"posts"> };
const { title, description, pubDate, tags } = entry.data;
const formatter = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric"
});
---
<article class="group rounded-2xl border border-black/5 bg-white/80 p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md dark:border-white/10 dark:bg-white/5">
  <div class="flex flex-col gap-3">
    <div class="flex items-center gap-3 text-xs font-sans uppercase tracking-wide text-black/50 dark:text-white/50">
      <span>{formatter.format(pubDate)}</span>
      <span class="h-1 w-1 rounded-full bg-black/30 dark:bg-white/40"></span>
      <span>Essay</span>
    </div>
    <h2 class="text-xl font-semibold">
      <a class="transition group-hover:text-[rgb(var(--accent))]" href={`/posts/${entry.slug}/`}>{title}</a>
    </h2>
    <p class="text-sm text-black/70 dark:text-white/70">{description}</p>
    {tags && (
      <div class="flex flex-wrap gap-2 text-xs font-sans">
        {tags.map((tag) => (
          <span class="rounded-full border border-black/10 bg-black/5 px-2 py-1 text-black/70 dark:border-white/10 dark:bg-white/10 dark:text-white/70">
            {tag}
          </span>
        ))}
      </div>
    )}
  </div>
</article>
