---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout pageTitle="About">
  <section class="grid gap-6">
    <h1 class="text-3xl font-semibold">About this blog</h1>
    <p class="text-base text-black/70 dark:text-white/70">
      This is a quiet personal blog for thoughtful notes on design, engineering, and daily rhythms.
    </p>
    <div class="rounded-2xl border border-black/5 bg-white/80 p-6 text-sm text-black/70 dark:border-white/10 dark:bg-white/5 dark:text-white/70">
      <p class="font-sans uppercase text-xs tracking-[0.2em] text-black/50 dark:text-white/50">Focus</p>
      <ul class="mt-4 grid gap-2">
        <li>Process notes from real projects.</li>
        <li>Readable essays over quick tips.</li>
        <li>Slow, calm, and consistent publishing.</li>
      </ul>
    </div>
  </section>
</BaseLayout>
